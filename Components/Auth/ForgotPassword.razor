@page "/forgot-password"
@layout AuthLayout
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject IToastService Toast

<div class="text-center mb-8">
    <div class="w-14 h-14 rounded-xl mx-auto mb-4 flex items-center justify-center"
         style="background: var(--accent); box-shadow: 0 0 24px rgba(245, 166, 35, 0.2);">
        <svg width="24" height="24" fill="black" viewBox="0 0 24 24">
            <path d="M15 7h1a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-2v4l-4-4H9a1.994 1.994 0 0 1-1.414-.586m0 0V11a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-2l-4 4v-4h-4"/>
        </svg>
    </div>
    <h1 class="text-2xl font-medium text-[var(--foreground)]">Quên mật khẩu?</h1>
    <p class="text-sm mt-1" style="color: var(--muted-foreground-2);">Nhập email để nhận link đặt lại mật khẩu.</p>
</div>

<div class="card">
    @if (_sent)
    {
        <div class="text-center py-4">
            <div class="w-12 h-12 rounded-full mx-auto mb-4 flex items-center justify-center" style="background: rgba(52,211,153,0.1);">
                <svg width="24" height="24" fill="none" stroke="#34d399" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            </div>
            <h3 class="text-lg font-medium mb-2">Đã gửi email!</h3>
            <p class="text-sm mb-6" style="color: var(--muted-foreground);">Nếu email tồn tại trong hệ thống, bạn sẽ nhận được link đặt lại mật khẩu.</p>
            <a href="/login" class="btn-primary inline-flex">Quay lại đăng nhập</a>
        </div>
    }
    else
    {
        <form @onsubmit="HandleSubmit">
            <div class="form-group mb-6">
                <label class="label">Email</label>
                <input class="input" type="email" @bind="_email" placeholder="email@example.com" />
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="mb-4 p-3 rounded-lg text-sm" style="background: rgba(239,68,68,0.1); color: #f87171;">
                    @_error
                </div>
            }

            <button type="submit" class="btn-primary w-full" disabled="@_loading">
                @if (_loading) {
                    <span class="w-4 h-4 border-2 border-t-black rounded-full animate-spin"></span>
                }
                Gửi email đặt lại
            </button>

            <div class="mt-4 text-center">
                <a href="/login" class="text-xs hover:underline" style="color: var(--muted-foreground);">
                    Quay lại đăng nhập
                </a>
            </div>
        </form>
    }
</div>

@code {
    private string _email = "";
    private bool _loading;
    private bool _sent;
    private string _error = "";

    private async Task HandleSubmit()
    {
        _loading = true;
        _error = "";
        var result = await AuthService.ForgotPasswordAsync(_email);
        _loading = false;
        if (result.IsSuccess)
            _sent = true;
        else
            _error = result.Error ?? "Có lỗi xảy ra.";
    }
}
