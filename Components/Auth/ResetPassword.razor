@page "/reset-password"
@rendermode InteractiveServer
@layout AuthLayout
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject IToastService Toast

<div class="text-center mb-8">
    <div class="w-14 h-14 rounded-xl mx-auto mb-4 flex items-center justify-center"
         style="background: var(--accent); box-shadow: 0 0 24px rgba(245, 166, 35, 0.2);">
        <svg width="24" height="24" fill="black" viewBox="0 0 24 24">
            <path d="M15 7h1a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-2v4l-4-4H9a1.994 1.994 0 0 1-1.414-.586m0 0V11a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-2l-4 4v-4h-4"/>
        </svg>
    </div>
    <h1 class="text-2xl font-medium text-[var(--foreground)]">Đặt lại mật khẩu</h1>
    <p class="text-sm mt-1" style="color: var(--muted-foreground-2);">Nhập mật khẩu mới của bạn.</p>
</div>

<div class="card">
    @if (_done)
    {
        <div class="text-center py-4">
            <div class="w-12 h-12 rounded-full mx-auto mb-4 flex items-center justify-center" style="background: rgba(52,211,153,0.1);">
                <svg width="24" height="24" fill="none" stroke="#34d399" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            </div>
            <h3 class="text-lg font-medium mb-2">Đổi mật khẩu thành công!</h3>
            <a href="/login" class="btn-primary inline-flex">Đăng nhập ngay</a>
        </div>
    }
    else
    {
        <form @onsubmit="HandleSubmit">
            <div class="form-group mb-4">
                <label class="label">Mật khẩu mới</label>
                <input class="input" type="password" @bind="_newPassword" placeholder="••••••••" />
            </div>
            <div class="form-group mb-6">
                <label class="label">Xác nhận mật khẩu</label>
                <input class="input" type="password" @bind="_confirmPassword" placeholder="••••••••" />
                @if (_confirmPassword.Length > 0 && _newPassword != _confirmPassword)
                {
                    <span class="form-error">Mật khẩu không khớp</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="mb-4 p-3 rounded-lg text-sm" style="background: rgba(239,68,68,0.1); color: #f87171;">
                    @_error
                </div>
            }

            <button type="submit" class="btn-primary w-full" disabled="@_loading">
                @if (_loading) {
                    <span class="w-4 h-4 border-2 border-t-black rounded-full animate-spin"></span>
                }
                Đặt lại mật khẩu
            </button>
        </form>
    }
</div>

@code {
    [SupplyParameterFromQuery] private string? token { get; set; }

    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _loading;
    private bool _done;
    private string _error = "";

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(token)) { _error = "Token không hợp lệ."; return; }
        if (_newPassword != _confirmPassword) { _error = "Mật khẩu không khớp."; return; }

        _loading = true;
        _error = "";

        var dto = new ResetPasswordDto(token, _newPassword);
        var result = await AuthService.ResetPasswordAsync(dto);

        _loading = false;

        if (result.IsSuccess)
        {
            Toast.Show(ToastType.Success, "Đổi mật khẩu thành công!");
            _done = true;
        }
        else
            _error = result.Error ?? "Có lỗi xảy ra.";
    }
}
