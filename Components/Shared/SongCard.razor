<div class="group relative cursor-pointer" @onclick="() => OnClick.InvokeAsync(Index)">
    <div class="relative aspect-square rounded-xl overflow-hidden bg-[#252528]">
        @if (!string.IsNullOrEmpty(Song.CoverImage))
        {
            <img src="@Song.CoverImage" alt="@Song.Title"
                 class="w-full h-full object-cover transition-all duration-300 group-hover:brightness-50" />
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center">
                <svg width="32" height="32" fill="none" stroke="var(--muted-foreground-3)" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M9 18V5l12-2v13M9 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm12 0c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2z"/>
                </svg>
            </div>
        }

        <!-- Hover play button -->
        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="w-12 h-12 rounded-full bg-[#F5A623] flex items-center justify-center shadow-lg"
                 style="box-shadow: 0 4px 16px rgba(245, 166, 35, 0.4);">
                <svg width="18" height="18" fill="black" viewBox="0 0 24 24">
                    <polygon points="5,3 19,12 5,21"/>
                </svg>
            </div>
        </div>
    </div>

    <!-- Track info -->
    <p class="mt-2 text-sm font-medium truncate text-[var(--foreground)]">@Song.Title</p>
    <p class="text-xs truncate text-[var(--muted-foreground)]">@Song.ArtistUsername</p>
    <p class="text-xs text-[var(--muted-foreground-2)] flex gap-3 mt-0.5">
        <span>@FormatPlays(Song.PlayCount)</span>
        <span>@FormatLikes(Song.LikeCount)</span>
    </p>
</div>

@code {
    [Parameter] public SongDto Song { get; set; } = null!;
    [Parameter] public int Index { get; set; }
    [Parameter] public EventCallback<int> OnClick { get; set; }

    private static string FormatPlays(int p) => p >= 1000 ? $"{p / 1000.0:F1}K plays" : $"{p} plays";
    private static string FormatLikes(int l) => l >= 1000 ? $"{l / 1000.0:F1}K" : $"{l}";
}
