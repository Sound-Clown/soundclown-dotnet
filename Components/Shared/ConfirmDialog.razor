@if (IsOpen)
{
    <div class="modal-overlay" @onclick="Cancel">
        <div class="modal" @onclick:stopPropagation>
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-medium">@Title</h3>
                <button class="btn-ghost p-1" @onclick="Cancel">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M18 6L6 18M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <p class="text-sm text-muted mb-6">@Message</p>
            <div class="flex justify-end gap-3">
                <button class="btn-ghost" @onclick="Cancel">Hủy</button>
                <button class="@ConfirmClass" @onclick="Confirm">@ConfirmText</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string Title { get; set; } = "Xác nhận";
    [Parameter] public string Message { get; set; } = "Bạn có chắc chắn?";
    [Parameter] public string ConfirmText { get; set; } = "Xác nhận";
    [Parameter] public string ConfirmClass { get; set; } = "btn-primary btn-danger";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private Task Confirm() => OnConfirm.InvokeAsync();
    private Task Cancel() => OnCancel.InvokeAsync();
}
