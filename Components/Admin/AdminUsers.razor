@page "/admin/users"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@inject IAdminService AdminService
@inject ICurrentUserService CurrentUser
@inject IToastService Toast

<div class="page-content">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl font-medium">Người dùng</h1>
        @if (_result?.Data != null)
        {
            <p class="text-xs" style="color: var(--muted-foreground-2);">@_result.Data.TotalCount tài khoản</p>
        }
    </div>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else if (_result?.Data != null)
    {
        <div class="space-y-3">
            @foreach (var user in _result.Data.Items)
            {
                var isSelf = user.Id == CurrentUser.UserId;
                <div class="card flex items-center gap-4 py-4">
                    <!-- Avatar -->
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold flex-shrink-0"
                         style="background: @(user.Role == Role.Admin ? "var(--accent)" : "var(--surface-2)"); color: @(user.Role == Role.Admin ? "black" : "var(--foreground)");">
                        @(user.Username.FirstOrDefault().ToString().ToUpper())
                    </div>

                    <!-- Info -->
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                            <p class="text-sm font-medium truncate">@user.Username</p>
                            @if (isSelf) {
                                <span class="text-xs px-2 py-0.5 rounded-full" style="background: rgba(245,166,35,0.1); color: var(--accent);">Bạn</span>
                            }
                        </div>
                        <p class="text-xs truncate" style="color: var(--muted-foreground-2);">@user.Email</p>
                    </div>

                    <!-- Badges -->
                    <div class="flex items-center gap-2 flex-shrink-0">
                        <RoleBadge Role="user.Role" />
                        @if (user.Role != Role.Admin)
                        {
                            <span class="badge @(user.IsActive ? "badge-active" : "badge-locked")">
                                @(user.IsActive ? "Hoạt động" : "Bị khóa")
                            </span>
                        }
                    </div>

                    <!-- Actions -->
                    @if (!isSelf && user.Role != Role.Admin)
                    {
                        <div class="flex-shrink-0">
                            @if (user.IsActive)
                            {
                                <button class="btn-danger-ghost text-xs py-1.5"
                                        disabled="@_locking"
                                        @onclick="() => ConfirmLock(user)">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                    </svg>
                                    Khóa
                                </button>
                            }
                            else
                            {
                                <button class="btn-ghost text-xs py-1.5"
                                        disabled="@_locking"
                                        @onclick="() => ConfirmLock(user)">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                        <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
                                    </svg>
                                    Mở khóa
                                </button>
                            }
                        </div>
                    }
                    else if (isSelf)
                    {
                        <div class="flex-shrink-0">
                            <span class="text-xs" style="color: var(--muted-foreground-3);">—</span>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (_result.Data.TotalPages > 1)
        {
            <div class="flex justify-center gap-2 mt-6">
                @for (int p = 1; p <= _result.Data.TotalPages; p++)
                {
                    <button class="w-8 h-8 rounded-lg text-sm font-medium"
                            style="background: @(p == _page ? "var(--accent)" : "var(--surface)"); color: @(p == _page ? "black" : "var(--foreground)");"
                            @onclick="() => LoadPage(p)">@p</button>
                }
            </div>
        }
    }
    else
    {
        <EmptyState Title="Không có dữ liệu" />
    }
</div>

<!-- Lock Confirm -->
<ConfirmDialog IsOpen="_confirmOpen"
               Title="Xác nhận khóa/mở khóa"
               Message='@(_targetUser?.IsActive == true ? $"Bạn có chắc muốn khóa tài khoản \"{_targetUser?.Username}\"?" : $"Bạn có chắc muốn mở khóa tài khoản \"{_targetUser?.Username}\"?")'
               ConfirmText="@(_targetUser?.IsActive == true ? "Khóa" : "Mở khóa")"
               ConfirmClass="@(_targetUser?.IsActive == true ? "btn-danger" : "btn-success")"
               OnConfirm="DoToggleLock"
               OnCancel="() => _confirmOpen = false" />

@code {
    private int _page = 1;
    private ServiceResult<PagedResult<UserDto>>? _result;
    private bool _loading;
    private bool _locking;
    private bool _confirmOpen;
    private UserDto? _targetUser;

    protected override async Task OnInitializedAsync() => await LoadPage(1);

    private async Task LoadPage(int page)
    {
        _loading = true;
        _page = page;
        _result = await AdminService.GetUsersAsync(page);
        _loading = false;
        StateHasChanged();
    }

    private void ConfirmLock(UserDto user)
    {
        _targetUser = user;
        _confirmOpen = true;
    }

    private async Task DoToggleLock()
    {
        if (_targetUser == null) return;
        _confirmOpen = false;
        _locking = true;
        var result = await AdminService.ToggleLockUserAsync(_targetUser.Id, CurrentUser.UserId!.Value);
        _locking = false;
        if (result.IsSuccess)
        {
            await LoadPage(_page);
            Toast.Show(ToastType.Success, _targetUser.IsActive ? "Đã khóa tài khoản." : "Đã mở khóa tài khoản.");
        }
        else
        {
            Toast.Show(ToastType.Error, result.Error ?? "Có lỗi xảy ra.");
        }
    }
}
