@page "/settings"
@rendermode InteractiveServer
@page "/change-password"
@inject IAuthService AuthService
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject IToastService Toast

<div class="page-content max-w-sm mx-auto">
    <h1 class="text-xl font-medium mb-6">Cài đặt</h1>

    <!-- Change password card -->
    <div class="card">
        <h2 class="text-base font-medium mb-4">Đổi mật khẩu</h2>

        @if (_success)
        {
            <div class="mb-4 p-3 rounded-lg text-sm flex items-center gap-2"
                 style="background: rgba(52,211,153,0.1); color: #34d399; border: 1px solid rgba(52,211,153,0.2);">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                Đổi mật khẩu thành công!
            </div>
        }

        <form @onsubmit="HandleSubmit">
            <div class="form-group mb-4">
                <label class="label">Mật khẩu hiện tại</label>
                <input class="input" type="password" @bind="_current" placeholder="••••••••" />
            </div>
            <div class="form-group mb-4">
                <label class="label">Mật khẩu mới</label>
                <input class="input" type="password" @bind="_newPass" placeholder="••••••••"
                       @oninput="UpdateStrength" />
                <!-- Strength meter -->
                <div class="strength-bar mt-1">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="strength-segment @(_strength > i ? _strengthClass : "")"></div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(_newPass) && _newPass.Length < 8)
                {
                    <span class="form-error">Mật khẩu phải ít nhất 8 ký tự</span>
                }
            </div>
            <div class="form-group mb-6">
                <label class="label">Xác nhận mật khẩu mới</label>
                <input class="input" type="password" @bind="_confirm" placeholder="••••••••" />
                @if (_confirm.Length > 0 && _newPass != _confirm)
                {
                    <span class="form-error">Mật khẩu không khớp</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="mb-4 p-3 rounded-lg text-sm" style="background: rgba(239,68,68,0.1); color: #f87171;">
                    @_error
                </div>
            }

            <button type="submit" class="btn-primary" disabled="@_loading">
                @if (_loading) { <span class="w-4 h-4 border-2 border-t-black rounded-full animate-spin"></span> }
                Đổi mật khẩu
            </button>
        </form>
    </div>
</div>

@code {
    private string _current = "";
    private string _newPass = "";
    private string _confirm = "";
    private bool _loading;
    private bool _success;
    private string _error = "";
    private int _strength;
    private string _strengthClass = "";

    private void UpdateStrength(ChangeEventArgs e)
    {
        _newPass = e.Value?.ToString() ?? "";
        (_strength, _strengthClass) = ComputeStrength(_newPass);
    }

    private static (int, string) ComputeStrength(string pwd)
    {
        if (string.IsNullOrEmpty(pwd)) return (0, "");
        int s = 0;
        if (pwd.Length >= 8) s++;
        if (pwd.Length >= 12) s++;
        if (pwd.Any(char.IsUpper) && pwd.Any(char.IsLower)) s++;
        if (pwd.Any(char.IsDigit) && pwd.Any(c => !char.IsLetterOrDigit(c))) s++;
        return s switch
        {
            <= 1 => (s, "red"),
            2 or 3 => (s, "amber"),
            _ => (s, "green"),
        };
    }

    private async Task HandleSubmit()
    {
        _loading = true;
        _error = "";
        _success = false;

        if (_newPass != _confirm)
        {
            _error = "Mật khẩu không khớp."; _loading = false; return;
        }
        if (_newPass.Length < 8)
        {
            _error = "Mật khẩu phải ít nhất 8 ký tự."; _loading = false; return;
        }

        var dto = new ChangePasswordDto(_current, _newPass, _confirm);
        var result = await AuthService.ChangePasswordAsync(CurrentUser.UserId!.Value, dto);

        _loading = false;
        if (result.IsSuccess)
        {
            _success = true;
            _current = _newPass = _confirm = "";
            Toast.Show(ToastType.Success, "Đổi mật khẩu thành công!");
        }
        else
        {
            _error = result.Error ?? "Có lỗi xảy ra.";
        }
    }
}
