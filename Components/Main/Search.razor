@page "/search"
@rendermode InteractiveServer
@inject ISongService SongService
@inject IPlayerService PlayerService
@inject ICurrentUserService CurrentUser
@inject IToastService Toast

<div class="page-content">
    <!-- Search input -->
    <div class="relative max-w-md mx-auto mb-8" style="height: 42px;">
        <svg class="absolute left-3" style="top: 13px; pointer-events: none;"
             width="16" height="16" fill="none"
             stroke="var(--muted-foreground)" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input class="input" style="padding-left: 2.25rem;"
               placeholder="Tìm bài hát, nghệ sĩ..."
               @bind="_query" @bind:event="oninput" />
    </div>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else if (!string.IsNullOrEmpty(_query) && _query.Length >= 2)
    {
        <!-- Artists section -->
        @if (_artists.Count > 0)
        {
            <div class="mb-8">
                <p class="text-xs font-medium uppercase tracking-wider mb-3" style="color: var(--muted-foreground-3);">
                    Nghệ sĩ
                </p>
                <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide">
                    @foreach (var artist in _artists)
                    {
                        <div class="flex-shrink-0 w-36 text-center">
                            <div class="w-24 h-24 rounded-full mx-auto mb-2 overflow-hidden"
                                 style="background: var(--surface);">
                                @if (!string.IsNullOrEmpty(artist.AvatarUrl))
                                {
                                    <img src="@artist.AvatarUrl" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center text-lg font-bold"
                                         style="background: var(--surface-2); color: var(--accent);">
                                        @artist.Username.First().ToString().ToUpper()
                                    </div>
                                }
                            </div>
                            <p class="text-xs font-medium truncate">@artist.Username</p>
                            <p class="text-xs truncate" style="color: var(--muted-foreground-3);">@artist.Role</p>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Songs section -->
        @if (_songs.Count > 0)
        {
            <div>
                <p class="text-xs font-medium uppercase tracking-wider mb-3" style="color: var(--muted-foreground-3);">
                    Bài hát
                </p>
                <div class="space-y-1">
                    @foreach (var item in _songs.Select((s, i) => (Song: s, Index: i)))
                    {
                        <SongRow Song="item.Song" Index="item.Index" ShowAlbum="true"
                                 OnClick="HandlePlay"
                                 OnToggleLike="() => ToggleLike(item.Song)" />
                    }
                </div>
            </div>
        }

        <!-- No results -->
        @if (_artists.Count == 0 && _songs.Count == 0)
        {
            <EmptyState Title="Không tìm thấy"
                        Description="@("Không có kết quả cho \"" + _query + "\"")" />
        }
    }
</div>

@code {
    private string _query = "";
    private List<SongDto> _songs = new();
    private List<ArtistSearchDto> _artists = new();
    private bool _loading;
    private System.Timers.Timer? _debounce;

    protected override void OnInitialized()
    {
        _debounce = new System.Timers.Timer(300);
        _debounce.Elapsed += async (_, _) =>
        {
            if (_query.Length < 2) { _songs = new(); _artists = new(); await InvokeAsync(StateHasChanged); return; }
            _loading = true;
            await InvokeAsync(StateHasChanged);
            var result = await SongService.SearchAsync(_query, CurrentUser.UserId ?? 0);
            _songs = result.Songs;
            _artists = result.Artists;
            _loading = false;
            await InvokeAsync(StateHasChanged);
        };
        _debounce.AutoReset = false;
    }

    private void OnInput(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? "";
        _debounce?.Stop();
        _debounce?.Start();
    }

    private void HandlePlay(int index)
    {
        if (_songs.Count == 0) return;
        var songs = _songs.Select(s => new PlayerSong(
            s.Id, s.Title, s.CoverImage, s.AudioFile,
            s.ArtistUsername, s.PlayCount, s.LikeCount, s.IsLiked)).ToList();
        PlayerService.SetQueue(songs, index, "search");
    }

    private async Task ToggleLike(SongDto song)
    {
        if (!CurrentUser.UserId.HasValue) return;
        var result = await SongService.ToggleLikeAsync(song.Id, CurrentUser.UserId.Value);
        if (result.IsSuccess) StateHasChanged();
        else Toast.Show(ToastType.Error, result.Error ?? "Lỗi");
    }
}
