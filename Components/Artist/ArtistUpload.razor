@page "/artist/upload"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Artist")]
@inject IUploadService UploadService
@inject ISongService SongService
@inject IAlbumService AlbumService
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject IToastService Toast
@inject IJSRuntime JSRuntime

<div class="page-content max-w-lg mx-auto">
    <h1 class="text-xl font-medium mb-6">Upload bài hát</h1>

    @if (_done)
    {
        <div class="card text-center py-8">
            <div class="w-14 h-14 rounded-full mx-auto mb-4 flex items-center justify-center" style="background: rgba(245,166,35,0.1);">
                <svg width="28" height="28" fill="none" stroke="var(--accent)" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            </div>
            <h3 class="text-lg font-medium mb-2">Upload thành công!</h3>
            <p class="text-sm mb-6" style="color: var(--muted-foreground);">Bài hát đang chờ admin duyệt.</p>
            <div class="flex justify-center gap-3">
                <a href="/artist/songs" class="btn-primary">Xem bài của tôi</a>
                <button class="btn-ghost" @onclick="Reset">Upload thêm</button>
            </div>
        </div>
    }
    else
    {
        <form @onsubmit="HandleSubmit">
            <!-- Title -->
            <div class="form-group mb-5">
                <label class="label">Tên bài hát</label>
                <input class="input" @bind="_title" placeholder="VD: Đêm không ngủ" />
                @if (!string.IsNullOrEmpty(_titleError))
                {
                    <span class="form-error">@_titleError</span>
                }
            </div>

            <!-- Album -->
            <div class="form-group mb-5">
                <label class="label">Album (tùy chọn)</label>
                <select class="input" @bind="_albumId">
                    <option value="">— Single (không album) —</option>
                    @foreach (var a in _albums)
                    {
                        <option value="@a.Id">@a.Name</option>
                    }
                </select>
            </div>

            <!-- Audio upload -->
            <div class="form-group mb-5">
                <label class="label">File âm thanh</label>
                <div class="upload-zone @(IsDraggingAudio ? "drag-over" : "") @(_audioLoading ? "opacity-60 pointer-events-none" : "")"
                     @ondragover:preventDefault @ondragover="() => IsDraggingAudio = true"
                     @ondragleave="() => IsDraggingAudio = false"
                     @ondrop.prevent="HandleAudioDrop"
                     @onclick='() => { if (!_audioLoading) TriggerAudioClick(); }'>
                    <InputFile id="audio-file-input" OnChange="HandleAudioSelect" accept=".mp3,audio/mpeg" class="sr-only" />
                    @if (_audioLoading)
                    {
                        <div class="text-center py-6">
                            <span class="w-6 h-6 border-2 border-t-[var(--accent)] rounded-full animate-spin mx-auto mb-2 block"></span>
                            <p class="text-sm" style="color: var(--muted-foreground);">Đang upload...</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(_audioFileName))
                    {
                        <div class="flex items-center gap-3">
                            <svg width="28" height="28" fill="none" stroke="var(--accent)" stroke-width="1.5" viewBox="0 0 24 24">
                                <path d="M9 18V5l12-2v13M9 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm12 0c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2z"/>
                            </svg>
                            <div>
                                <p class="text-sm font-medium">@_audioFileName</p>
                                <p class="text-xs" style="color: var(--muted-foreground-3);">@FormatSize(_audioFileSize)</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-6">
                            <svg width="28" height="28" fill="none" stroke="var(--muted-foreground-3)" stroke-width="1.5" viewBox="0 0 24 24" class="mx-auto mb-2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="17 8 12 3 7 8"/>
                                <line x1="12" y1="3" x2="12" y2="15"/>
                            </svg>
                            <p class="text-sm" style="color: var(--muted-foreground);">Kéo thả hoặc nhấn để chọn file MP3</p>
                            <p class="text-xs mt-1" style="color: var(--muted-foreground-3);">Tối đa 10MB</p>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(_audioError))
                {
                    <span class="form-error">@_audioError</span>
                }
            </div>

            <!-- Cover image upload -->
            <div class="form-group mb-6">
                <label class="label">Ảnh bìa (tùy chọn)</label>
                <div class="flex gap-4 items-start">
                    @if (_coverPreview != null)
                    {
                        <div class="relative flex-shrink-0">
                            <img src="@_coverPreview" class="w-24 h-24 rounded-xl object-cover" />
                            <button type="button" class="absolute -top-2 -right-2 w-6 h-6 rounded-full flex items-center justify-center"
                                    style="background: var(--surface-2);"
                                    @onclick="ClearCover">
                                <svg width="12" height="12" fill="none" stroke="var(--foreground)" stroke-width="2" viewBox="0 0 24 24">
                                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                                </svg>
                            </button>
                        </div>
                    }
                    <label class="upload-zone-sm @(IsDraggingCover ? "drag-over" : "") flex-1 cursor-pointer @( _coverLoading ? "opacity-60 pointer-events-none" : "")"
                           @ondragover:preventDefault @ondragover="() => IsDraggingCover = true"
                           @ondragleave="() => IsDraggingCover = false"
                           @ondrop.prevent="HandleCoverDrop">
                        <InputFile id="cover-file-input" OnChange="HandleCoverSelect" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" class="sr-only" />
                        @if (_coverLoading)
                        {
                            <div class="text-center">
                                <span class="w-5 h-5 border-2 border-t-[var(--accent)] rounded-full animate-spin mx-auto mb-1 block"></span>
                                <p class="text-xs" style="color: var(--muted-foreground-3);">Đang upload...</p>
                            </div>
                        }
                        else if (_coverPreview != null)
                        {
                            <p class="text-xs text-center" style="color: var(--muted-foreground-2);">Đổi ảnh</p>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <svg width="24" height="24" fill="none" stroke="var(--muted-foreground-3)" stroke-width="1.5" viewBox="0 0 24 24" class="mx-auto mb-1">
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                    <circle cx="8.5" cy="8.5" r="1.5"/>
                                    <polyline points="21 15 16 10 5 21"/>
                                </svg>
                                <p class="text-xs" style="color: var(--muted-foreground-3);">Ảnh JPG/PNG/WebP, tối đa 2MB</p>
                            </div>
                        }
                    </label>
                </div>
                @if (!string.IsNullOrEmpty(_coverError))
                {
                    <span class="form-error">@_coverError</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="mb-4 p-3 rounded-lg text-sm" style="background: rgba(239,68,68,0.1); color: #f87171;">
                    @_error
                </div>
            }

            <button type="submit" class="btn-primary w-full" disabled="@(_loading || _audioLoading)">
                @if (_loading) {
                    <span class="w-4 h-4 border-2 border-t-black rounded-full animate-spin"></span>
                }
                Upload bài hát
            </button>
        </form>
    }
</div>

<!-- Album list loader -->
@if (_albumsLoading)
{
    <LoadingSpinner />
}

<style>
.upload-zone {
    border: 2px dashed rgba(255,255,255,0.1);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    background: var(--surface);
}
.upload-zone:hover, .upload-zone.drag-over {
    border-color: var(--accent);
    background: rgba(245,166,35,0.05);
}
.upload-zone-sm {
    border: 2px dashed rgba(255,255,255,0.1);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    background: var(--surface);
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.upload-zone-sm:hover, .upload-zone-sm.drag-over {
    border-color: var(--accent);
    background: rgba(245,166,35,0.05);
}
</style>

@code {
    private string _title = "";
    private string _titleError = "";
    private string _error = "";
    private int? _albumId;
    private IBrowserFile? _audioFile;
    private string _audioFileName = "";
    private long _audioFileSize;
    private IBrowserFile? _coverFile;
    private string? _coverPreview;
    private string? _audioError;
    private string? _coverError;
    private string? _audioUrl;
    private string? _coverUrl;
    private bool _audioLoading;
    private bool _coverLoading;
    private bool _loading;
    private bool _done;
    private bool IsDraggingAudio;
    private bool IsDraggingCover;
    private bool _albumsLoading = true;
    private List<AlbumListDto> _albums = new();
    private record DropFileInfo(string Name, string ContentType, long Size, string Data);

    protected override async Task OnInitializedAsync()
    {
        var result = await AlbumService.GetArtistAlbumsAsync(CurrentUser.UserId!.Value);
        _albumsLoading = false;
        if (result.IsSuccess) _albums = result.Data!;
    }

    private async Task HandleAudioSelect(InputFileChangeEventArgs e)
    {
        _audioError = null;
        var file = e.File;
        if (file.ContentType != "audio/mpeg" && file.ContentType != "audio/mp3")
        {
            _audioError = "Chỉ chấp nhận file MP3."; Toast.Show(ToastType.Error, "Chỉ chấp nhận file MP3."); return;
        }
        if (file.Size > 10 * 1024 * 1024)
        {
            _audioError = "File tối đa 10MB."; Toast.Show(ToastType.Error, "File âm thanh tối đa 10MB."); return;
        }
        _audioLoading = true;
        await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        ms.Position = 0;
        var upload = await UploadService.UploadAudioAsync(ms, file.Name, file.ContentType, file.Size);
        _audioLoading = false;
        if (upload.IsSuccess)
        {
            _audioUrl = upload.Data!.Url;
            _audioFileName = file.Name;
            _audioFileSize = file.Size;
            _audioFile = file;
            Toast.Show(ToastType.Success, "Upload âm thanh thành công!");
        }
        else { _audioError = upload.Error; Toast.Show(ToastType.Error, upload.Error ?? "Upload thất bại."); }
    }

    private async Task HandleAudioDrop(DragEventArgs e)
    {
        IsDraggingAudio = false;
        var json = await JSRuntime.InvokeAsync<string?>("readDropFile", e.DataTransfer);
        if (string.IsNullOrEmpty(json)) { Toast.Show(ToastType.Error, "Không đọc được file."); return; }
        var dropFile = System.Text.Json.JsonSerializer.Deserialize<DropFileInfo>(json!);
        if (dropFile == null) { Toast.Show(ToastType.Error, "Không đọc được file."); return; }
        if (dropFile.ContentType != "audio/mpeg" && dropFile.ContentType != "audio/mp3")
        { _audioError = "Chỉ chấp nhận file MP3."; Toast.Show(ToastType.Error, "Chỉ chấp nhận file MP3."); return; }
        if (dropFile.Size > 10 * 1024 * 1024)
        { _audioError = "File tối đa 10MB."; Toast.Show(ToastType.Error, "File âm thanh tối đa 10MB."); return; }
        var bytes = Convert.FromBase64String(dropFile.Data);
        _audioLoading = true;
        using var ms = new MemoryStream(bytes);
        var upload = await UploadService.UploadAudioAsync(ms, dropFile.Name, dropFile.ContentType, bytes.Length);
        _audioLoading = false;
        if (upload.IsSuccess)
        { _audioUrl = upload.Data!.Url; _audioFileName = dropFile.Name; _audioFileSize = bytes.Length; _audioFile = null; Toast.Show(ToastType.Success, "Upload âm thanh thành công!"); }
        else { _audioError = upload.Error; Toast.Show(ToastType.Error, upload.Error ?? "Upload thất bại."); }
    }

    private void TriggerAudioClick() => JSRuntime.InvokeVoidAsync("triggerInputFile", "audio-file-input");

    private async Task HandleCoverSelect(InputFileChangeEventArgs e)
    {
        await ProcessCoverFile(e.File);
    }

    private async Task ProcessCoverFile(IBrowserFile file)
    {
        _coverFile = file;
        _coverLoading = true;
        _coverError = null;
        await using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        ms.Position = 0;
        var upload = await UploadService.UploadImageAsync(ms, file.Name, file.ContentType, file.Size);
        _coverLoading = false;
        if (upload.IsSuccess)
        {
            _coverUrl = upload.Data!.Url;
            _coverPreview = upload.Data.Url;
            Toast.Show(ToastType.Success, "Upload ảnh bìa thành công!");
        }
        else
        {
            _coverFile = null;
            _coverError = upload.Error;
            Toast.Show(ToastType.Error, upload.Error ?? "Upload ảnh thất bại.");
        }
    }

    private async Task HandleCoverDrop(DragEventArgs e)
    {
        IsDraggingCover = false;
        var json = await JSRuntime.InvokeAsync<string?>("readDropFile", e.DataTransfer);
        if (string.IsNullOrEmpty(json)) { Toast.Show(ToastType.Error, "Không đọc được file."); return; }
        var dropFile = System.Text.Json.JsonSerializer.Deserialize<DropFileInfo>(json!);
        if (dropFile == null) { Toast.Show(ToastType.Error, "Không đọc được file."); return; }
        var allowedTypes = new[] { "image/jpeg", "image/png", "image/webp" };
        if (!allowedTypes.Contains(dropFile.ContentType.ToLowerInvariant()))
        { Toast.Show(ToastType.Error, "Chỉ chấp nhận ảnh JPG, PNG hoặc WebP."); return; }
        if (dropFile.Size > 2 * 1024 * 1024)
        { Toast.Show(ToastType.Error, "Ảnh bìa tối đa 2MB."); return; }
        var bytes = Convert.FromBase64String(dropFile.Data);
        await ProcessCoverBytes(dropFile.Name, dropFile.ContentType, bytes);
    }

    private async Task ProcessCoverBytes(string fileName, string contentType, byte[] bytes)
    {
        _coverLoading = true;
        _coverError = null;
        using var ms = new MemoryStream(bytes);
        var upload = await UploadService.UploadImageAsync(ms, fileName, contentType, bytes.Length);
        _coverLoading = false;
        if (upload.IsSuccess)
        {
            _coverUrl = upload.Data!.Url;
            _coverPreview = upload.Data.Url;
            Toast.Show(ToastType.Success, "Upload ảnh bìa thành công!");
        }
        else
        {
            _coverFile = null;
            _coverError = upload.Error;
            Toast.Show(ToastType.Error, upload.Error ?? "Upload ảnh thất bại.");
        }
    }

    private void ClearCover()
    {
        _coverFile = null;
        _coverPreview = null;
        _coverUrl = null;
    }

    private async Task HandleSubmit()
    {
        _error = "";
        _titleError = "";
        if (string.IsNullOrWhiteSpace(_title)) { _titleError = "Vui lòng nhập tên bài hát."; return; }
        if (string.IsNullOrEmpty(_audioUrl)) { _audioError = "Vui lòng upload file âm thanh."; return; }

        _loading = true;
        var dto = new CreateSongDto(_title, _audioUrl!, _coverUrl, _albumId);
        var result = await SongService.CreateAsync(dto, CurrentUser.UserId!.Value);
        _loading = false;

        if (result.IsSuccess)
        {
            _done = true;
            Toast.Show(ToastType.Success, "Upload thành công! Bài hát đang chờ duyệt.");
        }
        else
        {
            _error = result.Error ?? "Có lỗi xảy ra.";
        }
    }

    private void Reset() { _done = false; _title = ""; _audioFile = null; _audioFileName = ""; _audioFileSize = 0; _coverFile = null; _coverPreview = null; _audioUrl = null; _coverUrl = null; }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes}B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1}KB";
        return $"{bytes / 1024.0 / 1024.0:F1}MB";
    }
}
