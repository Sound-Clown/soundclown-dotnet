@page "/artist/songs"
@attribute [Authorize(Roles = "Artist")]
@inject ISongService SongService
@inject IAlbumService AlbumService
@inject ICurrentUserService CurrentUser
@inject IToastService Toast
@inject IUploadService UploadService

<div class="page-content">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl font-medium">Bài của tôi</h1>
        <a href="/artist/upload" class="btn-primary">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Upload
        </a>
    </div>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else if (_songs != null && _songs.Count > 0)
    {
        <!-- Table -->
        <div class="space-y-2">
            @foreach (var song in _songs)
            {
                <div class="card flex items-center gap-4 py-3">
                    <!-- Cover -->
                    <div class="w-12 h-12 rounded-lg overflow-hidden bg-[#252528] flex-shrink-0">
                        @if (!string.IsNullOrEmpty(song.CoverImage))
                        {
                            <img src="@song.CoverImage" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <svg width="18" height="18" fill="none" stroke="var(--muted-foreground-3)" stroke-width="1.5" viewBox="0 0 24 24">
                                    <path d="M9 18V5l12-2v13M9 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm12 0c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2z"/>
                                </svg>
                            </div>
                        }
                    </div>

                    <!-- Info -->
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium truncate">@song.Title</p>
                        <p class="text-xs" style="color: var(--muted-foreground-2);">
                            @song.PlayCount plays · @song.LikeCount likes
                        </p>
                    </div>

                    <!-- Status -->
                    <SongStatusBadge Status="song.Status" RejectReason="song.RejectReason" />

                    <!-- Actions -->
                    <div class="flex gap-2">
                        <button class="btn-ghost p-2" @onclick="() => OpenEdit(song)">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                            </svg>
                        </button>
                        <button class="btn-danger-ghost p-2" @onclick="() => ConfirmDelete(song)">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <EmptyState Title="Bạn chưa upload bài hát nào"
                    Description="Hãy upload bài hát đầu tiên của bạn." />
    }
</div>

<!-- Edit Modal -->
@if (_editSong != null)
{
    <div class="modal-overlay" @onclick="() => _editSong = null">
        <div class="modal" @onclick:stopPropagation>
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-medium">Sửa bài hát</h3>
                <button class="btn-ghost p-1" @onclick="() => _editSong = null">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>

            <div class="form-group mb-4">
                <label class="label">Tên bài hát</label>
                <input class="input" @bind="_editTitle" />
            </div>
            <div class="form-group mb-4">
                <label class="label">Album</label>
                <select class="input" @bind="_editAlbumId">
                    <option value="">— Single —</option>
                    @foreach (var a in _albums)
                    {
                        <option value="@a.Id">@a.Name</option>
                    }
                </select>
            </div>
            <div class="form-group mb-6">
                <label class="label">Ảnh bìa (tùy chọn)</label>
                <InputFile OnChange="HandleEditCover" accept=".jpg,.jpeg,.png,.webp" />
            </div>

            @if (!string.IsNullOrEmpty(_editError))
            {
                <div class="mb-4 p-3 rounded-lg text-sm" style="background: rgba(239,68,68,0.1); color: #f87171;">@_editError</div>
            }

            <div class="flex justify-end gap-3">
                <button class="btn-ghost" @onclick="() => _editSong = null">Hủy</button>
                <button class="btn-primary" @onclick="SaveEdit" disabled="@_editLoading">
                    @if (_editLoading) { <span class="w-4 h-4 border-2 border-t-black rounded-full animate-spin"></span> }
                    Lưu
                </button>
            </div>
        </div>
    </div>
}

<!-- Delete Confirm -->
<ConfirmDialog IsOpen="_deleteConfirmOpen"
               Title="Xóa bài hát"
               Message=@($"Bạn có chắc muốn xóa \"{_deleteTarget?.Title}\"? Hành động này không thể hoàn tác.")
               ConfirmText="Xóa"
               ConfirmClass="btn-danger"
               OnConfirm="DoDelete"
               OnCancel="() => _deleteConfirmOpen = false" />

@code {
    private List<SongDto>? _songs;
    private List<AlbumListDto> _albums = new();
    private bool _loading;
    private SongDto? _editSong;
    private string _editTitle = "";
    private int? _editAlbumId;
    private string? _editCoverUrl;
    private bool _editLoading;
    private string _editError = "";
    private bool _deleteConfirmOpen;
    private SongDto? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        var songResult = await SongService.GetArtistSongsAsync(CurrentUser.UserId!.Value);
        var albumResult = await AlbumService.GetArtistAlbumsAsync(CurrentUser.UserId!.Value);
        _loading = false;
        if (songResult.IsSuccess) _songs = songResult.Data!;
        if (albumResult.IsSuccess) _albums = albumResult.Data!;
    }

    private void OpenEdit(SongDto song)
    {
        _editSong = song;
        _editTitle = song.Title;
        _editAlbumId = song.AlbumId;
        _editCoverUrl = song.CoverImage;
        _editError = "";
    }

    private async Task SaveEdit()
    {
        if (_editSong == null) return;
        _editLoading = true;
        _editError = "";
        var dto = new UpdateSongDto(_editTitle, _editCoverUrl, _editAlbumId);
        var result = await SongService.UpdateAsync(_editSong.Id, dto, CurrentUser.UserId!.Value);
        _editLoading = false;
        if (result.IsSuccess)
        {
            _editSong = null;
            await Load();
            Toast.Show(ToastType.Success, "Cập nhật thành công!");
        }
        else
        {
            _editError = result.Error ?? "Có lỗi xảy ra.";
        }
    }

    private async Task HandleEditCover(InputFileChangeEventArgs e)
    {
        var file = e.File;
        await using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        ms.Position = 0;
        var upload = await UploadService.UploadImageAsync(ms, file.Name, file.ContentType, file.Size);
        if (upload.IsSuccess)
        {
            _editCoverUrl = upload.Data!.Url;
        }
    }

    private void ConfirmDelete(SongDto song)
    {
        _deleteTarget = song;
        _deleteConfirmOpen = true;
    }

    private async Task DoDelete()
    {
        if (_deleteTarget == null) return;
        var result = await SongService.DeleteAsync(_deleteTarget.Id, CurrentUser.UserId!.Value);
        _deleteConfirmOpen = false;
        if (result.IsSuccess)
        {
            _songs?.Remove(_deleteTarget);
            Toast.Show(ToastType.Success, "Đã xóa bài hát.");
            StateHasChanged();
        }
        else
        {
            Toast.Show(ToastType.Error, result.Error ?? "Xóa thất bại.");
        }
    }
}
